<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dqms.ui.MainController"
      spacing="0" styleClass="root-pane">

    <!-- ── TOP BAR ──────────────────────────────────────────────────────── -->
    <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
        <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>

        <Label text="DQMS" styleClass="logo-text"/>
        <Label text="Decentralized Queue Management System" styleClass="top-subtitle"/>

        <Region HBox.hgrow="ALWAYS"/>

        <VBox alignment="CENTER_RIGHT" spacing="2">
            <Label fx:id="nodeLabel"   styleClass="node-badge" text="NODE_001"/>
            <Label fx:id="statusLabel" styleClass="status-label" text="● 0 peers connected"/>
        </VBox>
    </HBox>

    <!-- ── MAIN CONTENT ─────────────────────────────────────────────────── -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- LEFT: Student Join Panel -->
        <VBox styleClass="side-panel" spacing="14" minWidth="260" maxWidth="260">
            <padding><Insets top="24" right="20" bottom="24" left="20"/></padding>

            <Label text="Join Queue" styleClass="panel-title"/>
            <Separator/>

            <Label text="Registration Number" styleClass="field-label"/>
            <TextField fx:id="regNumberField"
                       promptText="e.g. EB1/66818/23"
                       styleClass="input-field"/>

            <Label text="Student Name" styleClass="field-label"/>
            <TextField fx:id="studentNameField"
                       promptText="e.g. William Otieno"
                       styleClass="input-field"/>

            <Button fx:id="joinButton"
                    text="Join Queue"
                    onAction="#onJoinQueue"
                    styleClass="primary-btn"
                    maxWidth="Infinity"/>

            <Label fx:id="joinFeedback" styleClass="feedback-label" text="" wrapText="true"/>

            <Separator/>

            <!-- Queue Stats -->
            <Label text="Queue Status" styleClass="panel-title"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Waiting:" styleClass="stat-label"/>
                <Label fx:id="waitingCount" text="0" styleClass="stat-value-waiting"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Cleared:" styleClass="stat-label"/>
                <Label fx:id="clearedCount" text="0" styleClass="stat-value-cleared"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Peers:" styleClass="stat-label"/>
                <Label fx:id="peerCount" text="0" styleClass="stat-value-peers"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Refresh"
                    onAction="#onRefresh"
                    styleClass="secondary-btn"
                    maxWidth="Infinity"/>
        </VBox>

        <!-- RIGHT: Queue Table -->
        <VBox VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" spacing="12" styleClass="table-pane">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Live Queue" styleClass="panel-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="clearBtn"
                        text="✓ Mark Cleared"
                        onAction="#onClearSelected"
                        styleClass="clear-btn"
                        disable="true"/>
            </HBox>

            <TableView fx:id="queueTable" VBox.vgrow="ALWAYS" styleClass="queue-table">
                <columns>
                    <TableColumn fx:id="posCol"    text="#"       prefWidth="45"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="regCol"    text="Reg No"  prefWidth="160"/>
                    <TableColumn fx:id="nameCol"   text="Name"    prefWidth="180"/>
                    <TableColumn fx:id="nodeCol"   text="Origin"  prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="timeCol"   text="Time"    prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="statusCol" text="Status"  prefWidth="110" style="-fx-alignment: CENTER;"/>
                </columns>
                <placeholder>
                    <Label text="No students in queue" styleClass="empty-label"/>
                </placeholder>
            </TableView>

            <Label fx:id="syncLog" styleClass="sync-log" text="Ready." wrapText="true"/>
        </VBox>
    </HBox>
</VBox>
